CC ?= gcc
CFLAGS = -Wall -Wextra -O2 -std=c99 -Iinclude
LDFLAGS =

TARGET = digital_lock
SRC = src/main.c src/lock_logic.c src/hw_io.c
OBJ = $(SRC:.c=.o)

all: $(TARGET)

$(TARGET): $(OBJ)
	$(CC) $(OBJ) -o $(TARGET) $(LDFLAGS)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f $(OBJ) $(TARGET)

.PHONY: all clean
